        function showTypingThenRespond(qNum) {
            const typingDiv = appendTyping();
            setTimeout(() => {
                typingDiv.remove();
                const resp = aiResponses[qNum];
                const content = resp.content.replace(/{STORE}/g, currentStore);
                appendAIResponse(content);
            }, 1200);
